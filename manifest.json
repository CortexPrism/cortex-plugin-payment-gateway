{
  "name": "cortex-plugin-payment-gateway",
  "version": "1.0.0",
  "description": "Payment Gateway Orchestrator — Route payments through optimal gateway (Stripe/Braintree/Adyen/Checkout.com) based on success rate, fees, and region",
  "kind": "esm",
  "entryPoint": "mod.ts",
  "runtime": "deno",
  "author": "CortexPrism",
  "license": "MIT",
  "repository": "https://github.com/CortexPrism/cortex-plugin-payment-gateway",
  "homepage": "https://cortexprism.io/marketplace/plugins/payment-gateway",
  "capabilities": ["tools", "network:fetch"],
  "tools": [
    {
      "name": "payments_process",
      "description": "Process payment through optimal gateway",
      "params": []
    },
    {
      "name": "payments_list_gateways",
      "description": "List configured gateways with health status",
      "params": []
    },
    {
      "name": "payments_get_transaction",
      "description": "Get transaction details and status",
      "params": []
    },
    {
      "name": "payments_refund",
      "description": "Process refund through original gateway",
      "params": []
    }
  ],
  "dependencies": {},
  "peerDependencies": { "cortex": ">=1.0.0" },
  "aiDisclosure": { "tools": ["Kilo (DeepSeek) — batch scaffold"], "humanReview": true }
}
